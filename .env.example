# bpstrategists.agencydashboard.io — single host for campaigns + GMB social posting.
#
# To auto-refresh BP_TOKEN + BP_SESSION, set BP_EMAIL + BP_PASSWORD and run:
#     bun run login
# That hits agencydashboard.io/ajax-do-login, follows the SSO bridge, and writes
# the fresh CSRF token + subdomain cookies back to this file. Re-run when the
# Laravel session expires (~24h).
BP_EMAIL=<your dashboard login email>
BP_PASSWORD=<your dashboard login password>

# Auto-populated by `bun run login` — do not edit by hand unless you're hand-copying
# cookies from DevTools. BP_SESSION must contain at minimum:
#   XSRF-TOKEN=...; agency_dashboard_session=...
# (subdomain-scoped to bpstrategists.agencydashboard.io). The client rolls Set-Cookie
# updates from each response, so a fresh login is good for ~24h.
BP_TOKEN=<csrf-token from <meta name="csrf-token">>
BP_SESSION=XSRF-TOKEN=<value>; agency_dashboard_session=<value>
BP_USER_ID=<numeric user id — stable per account, set once>

# Test fixture for HermesOps GMB
HERMES_CAMPAIGN_ID=<encrypted campaignId from /social-post/<id>>
HERMES_GMB_CHANNEL_ID=<numeric channel id>
