# dashboard.bpstrategists.com — single host for campaigns + GMB social posting.
BP_TOKEN=<csrf-token from <meta name="csrf-token">>
# Minimum: just the long-lived remember_web_* cookie. The client will capture and
# roll forward the session cookie automatically (via Set-Cookie).
BP_SESSION=remember_web_<id>=<value>
BP_USER_ID=<numeric user id>

# Test fixture for HermesOps GMB
HERMES_CAMPAIGN_ID=<encrypted campaignId from /social-post/<id>>
HERMES_GMB_CHANNEL_ID=<numeric channel id>
